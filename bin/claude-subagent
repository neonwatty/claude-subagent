#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="${CLAUDE_SUBAGENT_HOME:-$HOME/.claude-subagents}"
TASKS_DIR="$BASE_DIR/tasks"
WORKTREES_DIR="$BASE_DIR/worktrees"

usage() {
  cat <<'EOF'
Usage:
  claude-subagent init
  claude-subagent run <task-name> --prompt <file> --workdir <path> [--permission-mode <mode>] [--worktree] [--timeout <duration>]
  claude-subagent start <task-name> --prompt <file> --workdir <path> [--permission-mode <mode>] [--worktree] [--timeout <duration>]
  claude-subagent status <task-name>
  claude-subagent logs <task-name> [--tail <lines>]
  claude-subagent result <task-name>
  claude-subagent inspect <task-name>
  claude-subagent diff <task-name>
  claude-subagent integrate <task-name> --path <relative-path> [--path <relative-path> ...] [--force]
  claude-subagent stop <task-name>
  claude-subagent cleanup <task-name> [--worktree] [--branch] [--force]
  claude-subagent list

Environment:
  CLAUDE_SUBAGENT_HOME  Override storage directory. Defaults to ~/.claude-subagents.
EOF
}

fail() {
  printf 'claude-subagent: %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"
}

resolve_command() {
  command -v "$1" 2>/dev/null || fail "missing required command: $1"
}

validate_task_name() {
  local name="$1"
  [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || fail "invalid task name: $name"
}

validate_relative_path() {
  local path="$1"
  [[ -n "$path" ]] || fail "empty path is not allowed"
  [[ "$path" != /* ]] || fail "path must be relative: $path"
  [[ "$path" != "." ]] || fail "path must not be repository root"
  [[ "$path" != *"/../"* && "$path" != "../"* && "$path" != *"/.." ]] || fail "path must not contain ..: $path"
}

parse_duration_seconds() {
  local value="$1"
  if [[ "$value" =~ ^([0-9]+)([smh]?)$ ]]; then
    local amount="${BASH_REMATCH[1]}"
    local unit="${BASH_REMATCH[2]}"
    case "$unit" in
      ""|s) printf '%s\n' "$amount" ;;
      m) printf '%s\n' "$((amount * 60))" ;;
      h) printf '%s\n' "$((amount * 3600))" ;;
    esac
  else
    fail "invalid timeout duration: $value"
  fi
}

task_dir() {
  printf '%s/%s\n' "$TASKS_DIR" "$1"
}

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

shell_quote() {
  local value="$1"
  printf "'%s'" "${value//\'/\'\\\'\'}"
}

now_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

ensure_base_dirs() {
  mkdir -p "$TASKS_DIR"
  mkdir -p "$WORKTREES_DIR"
}

read_file_or_empty() {
  local file="$1"
  if [[ -f "$file" ]]; then
    cat "$file"
  fi
}

git_status_short() {
  local workdir="$1"
  git -C "$workdir" status --short --untracked-files=all
}

git_untracked_files() {
  local workdir="$1"
  git -C "$workdir" ls-files --others --exclude-standard
}

print_git_review_summary() {
  local workdir="$1"
  local status unstaged_stat staged_stat untracked_files
  status="$(git_status_short "$workdir")"
  if [[ -z "$status" ]]; then
    printf 'clean\n'
    return 0
  fi

  unstaged_stat="$(git -C "$workdir" diff --stat)"
  staged_stat="$(git -C "$workdir" diff --cached --stat)"
  untracked_files="$(git_untracked_files "$workdir")"

  printf 'Git status:\n%s\n' "$status"
  if [[ -n "$staged_stat" ]]; then
    printf '\nStaged diff stat:\n%s\n' "$staged_stat"
  fi
  if [[ -n "$unstaged_stat" ]]; then
    printf '\nUnstaged diff stat:\n%s\n' "$unstaged_stat"
  fi
  if [[ -n "$untracked_files" ]]; then
    printf '\nUntracked files:\n%s\n' "$untracked_files"
  fi
}

print_untracked_file_diffs() {
  local workdir="$1"
  local file abs_file size

  git_untracked_files "$workdir" | while IFS= read -r file; do
    [[ -n "$file" ]] || continue
    abs_file="$workdir/$file"
    [[ -f "$abs_file" ]] || continue

    printf '\nUntracked file: %s\n' "$file"
    if grep -Iq . "$abs_file"; then
      size="$(wc -c <"$abs_file" | tr -d ' ')"
      if [[ "$size" -gt 200000 ]]; then
        printf 'Skipped content: file is larger than 200KB.\n'
      else
        git -C "$workdir" diff --no-index -- /dev/null "$file" || true
      fi
    else
      printf 'Skipped content: binary file.\n'
    fi
  done
}

copy_approved_path() {
  local from_root="$1"
  local to_root="$2"
  local rel_path="$3"
  local src="$from_root/$rel_path"
  local dst="$to_root/$rel_path"

  [[ -e "$src" ]] || fail "approved path does not exist in task workdir: $rel_path"

  if [[ -d "$src" ]]; then
    mkdir -p "$dst"
    cp -R "$src"/. "$dst"/
  else
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
  fi
}

extract_result() {
  local dir="$1"
  local stdout_log="$dir/stdout.log"
  local result_file="$dir/result.txt"

  [[ -f "$stdout_log" ]] || return 0

  if command -v ruby >/dev/null 2>&1; then
    ruby -rjson -e '
      texts = []
      File.foreach(ARGV[0]) do |line|
        begin
          event = JSON.parse(line)
        rescue JSON::ParserError
          next
        end

        if event["type"] == "result" && event["result"]
          texts << event["result"].to_s
        elsif event["type"] == "assistant" && event["message"].is_a?(Hash)
          Array(event["message"]["content"]).each do |part|
            if part.is_a?(Hash) && part["type"] == "text" && part["text"]
              texts << part["text"].to_s
            end
          end
        elsif event["type"] == "message" && event["content"]
          texts << event["content"].to_s
        end
      end
      puts texts.reject(&:empty?).last.to_s
    ' "$stdout_log" >"$result_file.tmp" 2>/dev/null || true

    if [[ -s "$result_file.tmp" ]]; then
      mv "$result_file.tmp" "$result_file"
      return 0
    fi
    rm -f "$result_file.tmp"
  fi

  cp "$stdout_log" "$result_file"
}

write_metadata() {
  local dir="$1"
  local name="$2"
  local mode="$3"
  local prompt_file="$4"
  local workdir="$5"
  local permission_mode="$6"
  local source_workdir="$7"
  local worktree_enabled="$8"
  local worktree_branch="$9"
  local worktree_path="${10}"
  local source_branch="${11}"
  local source_dirty="${12}"
  local session_name="${13:-}"
  local timeout_seconds="${14:-}"
  local created_at
  created_at="$(now_utc)"

  printf '%s\n' "$mode" >"$dir/mode"
  printf '%s\n' "$created_at" >"$dir/created-at"
  printf '%s\n' "$workdir" >"$dir/workdir"
  printf '%s\n' "$permission_mode" >"$dir/permission-mode"
  printf '%s\n' "$source_workdir" >"$dir/source-workdir"
  printf '%s\n' "$worktree_enabled" >"$dir/worktree-enabled"
  if [[ -n "$worktree_branch" ]]; then
    printf '%s\n' "$worktree_branch" >"$dir/worktree-branch"
  fi
  if [[ -n "$worktree_path" ]]; then
    printf '%s\n' "$worktree_path" >"$dir/worktree-path"
  fi
  if [[ -n "$source_branch" ]]; then
    printf '%s\n' "$source_branch" >"$dir/source-branch"
  fi
  printf '%s\n' "$source_dirty" >"$dir/source-dirty"
  if [[ -n "$session_name" ]]; then
    printf '%s\n' "$session_name" >"$dir/session"
  fi
  if [[ -n "$timeout_seconds" ]]; then
    printf '%s\n' "$timeout_seconds" >"$dir/timeout-seconds"
  fi

  cat >"$dir/metadata.json" <<EOF
{
  "taskName": "$(json_escape "$name")",
  "mode": "$(json_escape "$mode")",
  "promptPath": "$(json_escape "$prompt_file")",
  "workdir": "$(json_escape "$workdir")",
  "permissionMode": "$(json_escape "$permission_mode")",
  "sourceWorkdir": "$(json_escape "$source_workdir")",
  "worktreeEnabled": "$(json_escape "$worktree_enabled")",
  "worktreeBranch": "$(json_escape "$worktree_branch")",
  "worktreePath": "$(json_escape "$worktree_path")",
  "sourceBranch": "$(json_escape "$source_branch")",
  "sourceDirty": "$(json_escape "$source_dirty")",
  "sessionName": "$(json_escape "$session_name")",
  "timeoutSeconds": "$(json_escape "$timeout_seconds")",
  "createdAt": "$(json_escape "$created_at")"
}
EOF
}

parse_prompt_and_workdir() {
  PROMPT_FILE=""
  WORKDIR=""
  PERMISSION_MODE="default"
  USE_WORKTREE="false"
  TIMEOUT_SECONDS=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --prompt)
        [[ $# -ge 2 ]] || fail "--prompt requires a file"
        PROMPT_FILE="$2"
        shift 2
        ;;
      --workdir)
        [[ $# -ge 2 ]] || fail "--workdir requires a path"
        WORKDIR="$2"
        shift 2
        ;;
      --permission-mode)
        [[ $# -ge 2 ]] || fail "--permission-mode requires a mode"
        case "$2" in
          acceptEdits|auto|bypassPermissions|default|dontAsk|plan)
            PERMISSION_MODE="$2"
            ;;
          *)
            fail "invalid permission mode: $2"
            ;;
        esac
        shift 2
        ;;
      --worktree)
        USE_WORKTREE="true"
        shift
        ;;
      --timeout)
        [[ $# -ge 2 ]] || fail "--timeout requires a duration"
        TIMEOUT_SECONDS="$(parse_duration_seconds "$2")"
        [[ "$TIMEOUT_SECONDS" -gt 0 ]] || fail "--timeout must be greater than zero"
        shift 2
        ;;
      *)
        fail "unknown option: $1"
        ;;
    esac
  done

  [[ -n "$PROMPT_FILE" ]] || fail "--prompt is required"
  [[ -f "$PROMPT_FILE" ]] || fail "prompt file not found: $PROMPT_FILE"
  [[ -n "$WORKDIR" ]] || fail "--workdir is required"
  [[ -d "$WORKDIR" ]] || fail "workdir not found: $WORKDIR"

  PROMPT_FILE="$(cd "$(dirname "$PROMPT_FILE")" && pwd)/$(basename "$PROMPT_FILE")"
  WORKDIR="$(cd "$WORKDIR" && pwd)"
}

run_with_timeout() {
  local timeout_seconds="$1"
  shift

  if [[ -z "$timeout_seconds" ]]; then
    "$@"
    return $?
  fi

  "$@" &
  local pid=$!
  local elapsed=0

  while kill -0 "$pid" >/dev/null 2>&1; do
    if [[ "$elapsed" -ge "$timeout_seconds" ]]; then
      kill -TERM "$pid" >/dev/null 2>&1 || true
      sleep 2
      if kill -0 "$pid" >/dev/null 2>&1; then
        kill -KILL "$pid" >/dev/null 2>&1 || true
      fi
      wait "$pid" 2>/dev/null || true
      return 124
    fi
    sleep 1
    elapsed=$((elapsed + 1))
  done

  wait "$pid"
}

prepare_execution_workdir() {
  local name="$1"
  local dir="$2"

  SOURCE_WORKDIR="$WORKDIR"
  EXEC_WORKDIR="$WORKDIR"
  WORKTREE_BRANCH=""
  WORKTREE_PATH=""
  SOURCE_BRANCH=""
  SOURCE_DIRTY="unknown"

  if git -C "$SOURCE_WORKDIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    SOURCE_BRANCH="$(git -C "$SOURCE_WORKDIR" branch --show-current 2>/dev/null || true)"
    if [[ -z "$SOURCE_BRANCH" ]]; then
      SOURCE_BRANCH="$(git -C "$SOURCE_WORKDIR" rev-parse --short HEAD 2>/dev/null || true)"
    fi
    if [[ -n "$(git -C "$SOURCE_WORKDIR" status --porcelain)" ]]; then
      SOURCE_DIRTY="true"
    else
      SOURCE_DIRTY="false"
    fi
  fi

  if [[ "$USE_WORKTREE" != "true" ]]; then
    return
  fi

  require_command git
  git -C "$SOURCE_WORKDIR" rev-parse --is-inside-work-tree >/dev/null 2>&1 || fail "--worktree requires --workdir to be inside a git repository"

  local repo_root prefix worktree_exec_subdir
  repo_root="$(git -C "$SOURCE_WORKDIR" rev-parse --show-toplevel)"
  prefix="$(git -C "$SOURCE_WORKDIR" rev-parse --show-prefix)"
  WORKTREE_BRANCH="claude-subagent/$name"
  WORKTREE_PATH="$WORKTREES_DIR/$name"

  [[ ! -e "$WORKTREE_PATH" ]] || fail "worktree path already exists: $WORKTREE_PATH"
  if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$WORKTREE_BRANCH"; then
    fail "worktree branch already exists: $WORKTREE_BRANCH"
  fi

  git -C "$repo_root" worktree add -b "$WORKTREE_BRANCH" "$WORKTREE_PATH" HEAD >"$dir/worktree-create.log" 2>&1 || {
    cat "$dir/worktree-create.log" >&2
    fail "failed to create worktree"
  }

  worktree_exec_subdir="${prefix%/}"
  if [[ -n "$worktree_exec_subdir" ]]; then
    EXEC_WORKDIR="$WORKTREE_PATH/$worktree_exec_subdir"
  else
    EXEC_WORKDIR="$WORKTREE_PATH"
  fi
}

task_status_value() {
  local name="$1"
  local dir
  dir="$(task_dir "$name")"

  if [[ ! -d "$dir" ]]; then
    printf 'unknown\n'
    return
  fi

  if [[ -f "$dir/session" ]]; then
    local session
    session="$(cat "$dir/session")"
    if tmux has-session -t "$session" >/dev/null 2>&1; then
      printf 'running\n'
      return
    fi
  fi

  if [[ -f "$dir/exit-code" ]]; then
    local code
    code="$(cat "$dir/exit-code")"
    if [[ "$code" == "0" ]]; then
      printf 'succeeded\n'
    else
      printf 'failed\n'
    fi
    return
  fi

  printf 'created\n'
}

cmd_init() {
  require_command claude
  require_command git
  require_command tmux
  ensure_base_dirs
  printf 'initialized %s\n' "$BASE_DIR"
}

cmd_run() {
  [[ $# -ge 1 ]] || fail "run requires a task name"
  local name="$1"
  shift
  validate_task_name "$name"
  parse_prompt_and_workdir "$@"
  require_command claude
  local claude_bin
  claude_bin="$(resolve_command claude)"
  ensure_base_dirs

  local dir prompt exit_code
  dir="$(task_dir "$name")"
  rm -rf "$dir"
  mkdir -p "$dir"
  cp "$PROMPT_FILE" "$dir/prompt.md"
  prepare_execution_workdir "$name" "$dir"
  write_metadata "$dir" "$name" "run" "$PROMPT_FILE" "$EXEC_WORKDIR" "$PERMISSION_MODE" "$SOURCE_WORKDIR" "$USE_WORKTREE" "$WORKTREE_BRANCH" "$WORKTREE_PATH" "$SOURCE_BRANCH" "$SOURCE_DIRTY" "" "$TIMEOUT_SECONDS"
  prompt="$(cat "$PROMPT_FILE")"

  set +e
  (
    cd "$EXEC_WORKDIR" || exit 1
    run_with_timeout "$TIMEOUT_SECONDS" "$claude_bin" "$prompt" --print --verbose --output-format stream-json --permission-mode "$PERMISSION_MODE" --add-dir "$dir" >"$dir/stdout.log" 2>"$dir/stderr.log"
  )
  exit_code=$?
  set -e

  printf '%s\n' "$exit_code" >"$dir/exit-code"
  if [[ "$exit_code" -eq 124 && -n "$TIMEOUT_SECONDS" ]]; then
    printf 'timeout after %s seconds\n' "$TIMEOUT_SECONDS" >"$dir/timed-out"
    printf 'claude-subagent: timeout after %s seconds\n' "$TIMEOUT_SECONDS" >>"$dir/stderr.log"
  fi
  extract_result "$dir"
  cat "$dir/stdout.log"
  if [[ "$exit_code" -ne 0 ]]; then
    cat "$dir/stderr.log" >&2
  fi
  return "$exit_code"
}

cmd_start() {
  [[ $# -ge 1 ]] || fail "start requires a task name"
  local name="$1"
  shift
  validate_task_name "$name"
  parse_prompt_and_workdir "$@"
  require_command claude
  require_command tmux
  local claude_bin
  claude_bin="$(resolve_command claude)"
  ensure_base_dirs

  local dir session
  dir="$(task_dir "$name")"
  session="claude-subagent-${name//./-}"

  if tmux has-session -t "$session" >/dev/null 2>&1; then
    fail "tmux session already exists: $session"
  fi

  rm -rf "$dir"
  mkdir -p "$dir"
  cp "$PROMPT_FILE" "$dir/prompt.md"
  prepare_execution_workdir "$name" "$dir"
  write_metadata "$dir" "$name" "start" "$PROMPT_FILE" "$EXEC_WORKDIR" "$PERMISSION_MODE" "$SOURCE_WORKDIR" "$USE_WORKTREE" "$WORKTREE_BRANCH" "$WORKTREE_PATH" "$SOURCE_BRANCH" "$SOURCE_DIRTY" "$session" "$TIMEOUT_SECONDS"

  cat >"$dir/runner.sh" <<EOF
#!/usr/bin/env bash
set +e
run_with_timeout() {
  local timeout_seconds="\$1"
  shift

  if [[ -z "\$timeout_seconds" ]]; then
    "\$@"
    return \$?
  fi

  "\$@" &
  local pid=\$!
  local elapsed=0

  while kill -0 "\$pid" >/dev/null 2>&1; do
    if [[ "\$elapsed" -ge "\$timeout_seconds" ]]; then
      kill -TERM "\$pid" >/dev/null 2>&1 || true
      sleep 2
      if kill -0 "\$pid" >/dev/null 2>&1; then
        kill -KILL "\$pid" >/dev/null 2>&1 || true
      fi
      wait "\$pid" 2>/dev/null || true
      return 124
    fi
    sleep 1
    elapsed=\$((elapsed + 1))
  done

  wait "\$pid"
}

cd $(shell_quote "$EXEC_WORKDIR") || exit 1
prompt="\$(cat $(shell_quote "$dir/prompt.md"))"
run_with_timeout $(shell_quote "$TIMEOUT_SECONDS") $(shell_quote "$claude_bin") "\$prompt" --print --verbose --output-format stream-json --permission-mode $(shell_quote "$PERMISSION_MODE") --add-dir $(shell_quote "$dir") >$(shell_quote "$dir/stdout.log") 2>$(shell_quote "$dir/stderr.log")
code=\$?
printf '%s\n' "\$code" >$(shell_quote "$dir/exit-code")
if [[ "\$code" -eq 124 && -n $(shell_quote "$TIMEOUT_SECONDS") ]]; then
  printf 'timeout after %s seconds\n' $(shell_quote "$TIMEOUT_SECONDS") >$(shell_quote "$dir/timed-out")
  printf 'claude-subagent: timeout after %s seconds\n' $(shell_quote "$TIMEOUT_SECONDS") >>$(shell_quote "$dir/stderr.log")
fi
if command -v ruby >/dev/null 2>&1; then
  ruby -rjson -e '
    texts = []
    File.foreach(ARGV[0]) do |line|
      begin
        event = JSON.parse(line)
      rescue JSON::ParserError
        next
      end

      if event["type"] == "result" && event["result"]
        texts << event["result"].to_s
      elsif event["type"] == "assistant" && event["message"].is_a?(Hash)
        Array(event["message"]["content"]).each do |part|
          if part.is_a?(Hash) && part["type"] == "text" && part["text"]
            texts << part["text"].to_s
          end
        end
      elsif event["type"] == "message" && event["content"]
        texts << event["content"].to_s
      end
    end
    puts texts.reject(&:empty?).last.to_s
  ' $(shell_quote "$dir/stdout.log") >$(shell_quote "$dir/result.txt.tmp") 2>/dev/null || true
  if [[ -s $(shell_quote "$dir/result.txt.tmp") ]]; then
    mv $(shell_quote "$dir/result.txt.tmp") $(shell_quote "$dir/result.txt")
  else
    rm -f $(shell_quote "$dir/result.txt.tmp")
    cp $(shell_quote "$dir/stdout.log") $(shell_quote "$dir/result.txt")
  fi
else
  cp $(shell_quote "$dir/stdout.log") $(shell_quote "$dir/result.txt")
fi
exit "\$code"
EOF
  chmod +x "$dir/runner.sh"

  tmux new-session -d -s "$session" "$(shell_quote "$dir/runner.sh")"
  printf 'started %s\n' "$name"
  printf 'session %s\n' "$session"
}

cmd_status() {
  [[ $# -eq 1 ]] || fail "status requires one task name"
  validate_task_name "$1"
  printf '%s\n' "$(task_status_value "$1")"
}

cmd_logs() {
  [[ $# -ge 1 ]] || fail "logs requires a task name"
  local name="$1"
  shift
  validate_task_name "$name"

  local lines=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tail)
        [[ $# -ge 2 ]] || fail "--tail requires a line count"
        lines="$2"
        shift 2
        ;;
      *)
        fail "unknown option: $1"
        ;;
    esac
  done

  local dir
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"

  if [[ -n "$lines" ]]; then
    tail -n "$lines" "$dir/stdout.log" 2>/dev/null || true
    tail -n "$lines" "$dir/stderr.log" 2>/dev/null || true
  else
    read_file_or_empty "$dir/stdout.log"
    read_file_or_empty "$dir/stderr.log"
  fi
}

cmd_result() {
  [[ $# -eq 1 ]] || fail "result requires one task name"
  local name="$1"
  validate_task_name "$name"

  local dir
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"
  if [[ ! -f "$dir/result.txt" && -f "$dir/stdout.log" ]]; then
    extract_result "$dir"
  fi
  [[ -f "$dir/result.txt" ]] || fail "task has no result yet: $name"
  cat "$dir/result.txt"
}

cmd_inspect() {
  [[ $# -eq 1 ]] || fail "inspect requires one task name"
  local name="$1"
  validate_task_name "$name"

  local dir status mode created workdir source_workdir source_branch source_dirty worktree_enabled worktree_path worktree_branch permission_mode timeout_seconds session report_path
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"

  status="$(task_status_value "$name")"
  mode="$(read_file_or_empty "$dir/mode")"
  created="$(read_file_or_empty "$dir/created-at")"
  workdir="$(read_file_or_empty "$dir/workdir")"
  source_workdir="$(read_file_or_empty "$dir/source-workdir")"
  source_branch="$(read_file_or_empty "$dir/source-branch")"
  source_dirty="$(read_file_or_empty "$dir/source-dirty")"
  worktree_enabled="$(read_file_or_empty "$dir/worktree-enabled")"
  worktree_path="$(read_file_or_empty "$dir/worktree-path")"
  worktree_branch="$(read_file_or_empty "$dir/worktree-branch")"
  permission_mode="$(read_file_or_empty "$dir/permission-mode")"
  timeout_seconds="$(read_file_or_empty "$dir/timeout-seconds")"
  session="$(read_file_or_empty "$dir/session")"
  report_path="$dir/report.md"

  printf 'Task: %s\n' "$name"
  printf 'Status: %s\n' "$status"
  printf 'Mode: %s\n' "$mode"
  printf 'Created: %s\n' "$created"
  printf 'Permission mode: %s\n' "$permission_mode"
  if [[ -n "$timeout_seconds" ]]; then
    printf 'Timeout seconds: %s\n' "$timeout_seconds"
  fi
  if [[ -f "$dir/timed-out" ]]; then
    printf 'Timed out: %s\n' "$(read_file_or_empty "$dir/timed-out")"
  fi
  if [[ -n "$session" ]]; then
    printf 'Session: %s\n' "$session"
  fi
  printf 'Workdir: %s\n' "$workdir"
  if [[ -n "$source_workdir" ]]; then
    printf 'Source workdir: %s\n' "$source_workdir"
  fi
  if [[ -n "$source_branch" ]]; then
    printf 'Source branch: %s\n' "$source_branch"
  fi
  if [[ -n "$source_dirty" ]]; then
    printf 'Source dirty: %s\n' "$source_dirty"
  fi
  printf 'Worktree enabled: %s\n' "${worktree_enabled:-false}"
  if [[ -n "$worktree_path" ]]; then
    printf 'Worktree path: %s\n' "$worktree_path"
  fi
  if [[ -n "$worktree_branch" ]]; then
    printf 'Worktree branch: %s\n' "$worktree_branch"
  fi
  if [[ -f "$report_path" ]]; then
    printf 'Report: %s\n' "$report_path"
  fi

  if [[ -f "$dir/result.txt" ]]; then
    printf '\nResult:\n'
    cat "$dir/result.txt"
    printf '\n'
  fi

  if [[ -n "$workdir" ]] && git -C "$workdir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf '\nDiff stat:\n'
    print_git_review_summary "$workdir"
  fi
}

cmd_diff() {
  [[ $# -eq 1 ]] || fail "diff requires one task name"
  local name="$1"
  validate_task_name "$name"

  local dir workdir
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"
  [[ -f "$dir/workdir" ]] || fail "task has no recorded workdir: $name"
  workdir="$(cat "$dir/workdir")"
  git -C "$workdir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || fail "workdir is not a git repository: $workdir"
  printf 'Diff stat:\n'
  print_git_review_summary "$workdir"
  printf '\n'
  git -C "$workdir" diff --cached --stat
  git -C "$workdir" diff --stat
  git -C "$workdir" diff --cached
  git -C "$workdir" diff
  print_untracked_file_diffs "$workdir"
}

cmd_integrate() {
  [[ $# -ge 3 ]] || fail "integrate requires a task name and at least one --path"
  local name="$1"
  shift
  validate_task_name "$name"

  local force="false"
  local paths=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --path|--paths)
        [[ $# -ge 2 ]] || fail "$1 requires a relative path"
        validate_relative_path "$2"
        paths+=("$2")
        shift 2
        ;;
      --force)
        force="true"
        shift
        ;;
      *)
        fail "unknown option: $1"
        ;;
    esac
  done
  [[ "${#paths[@]}" -gt 0 ]] || fail "integrate requires at least one --path"

  local dir status workdir source_workdir path path_status audit_file
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"
  status="$(task_status_value "$name")"
  [[ "$status" != "running" ]] || fail "cannot integrate running task: $name"

  workdir="$(read_file_or_empty "$dir/workdir")"
  source_workdir="$(read_file_or_empty "$dir/source-workdir")"
  [[ -n "$workdir" ]] || fail "task has no recorded workdir: $name"
  [[ -n "$source_workdir" ]] || fail "task has no recorded source workdir; integrate requires a --worktree task"
  git -C "$workdir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || fail "task workdir is not a git repository: $workdir"
  git -C "$source_workdir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || fail "source workdir is not a git repository: $source_workdir"

  for path in "${paths[@]}"; do
    [[ -e "$workdir/$path" ]] || fail "approved path does not exist in task workdir: $path"
    path_status="$(git -C "$source_workdir" status --short --untracked-files=all -- "$path")"
    if [[ -n "$path_status" && "$force" != "true" ]]; then
      fail "source path has local changes; use --force to overwrite: $path"
    fi
  done

  audit_file="$dir/integrated-paths.log"
  {
    printf 'integrated-at: %s\n' "$(now_utc)"
    printf 'source-workdir: %s\n' "$source_workdir"
    printf 'task-workdir: %s\n' "$workdir"
  } >>"$audit_file"

  for path in "${paths[@]}"; do
    copy_approved_path "$workdir" "$source_workdir" "$path"
    printf 'path: %s\n' "$path" >>"$audit_file"
    printf 'integrated %s -> %s\n' "$path" "$source_workdir/$path"
  done
}

cmd_cleanup() {
  [[ $# -ge 1 ]] || fail "cleanup requires a task name"
  local name="$1"
  shift
  validate_task_name "$name"

  local remove_worktree="false"
  local remove_branch="false"
  local force_remove="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --worktree)
        remove_worktree="true"
        shift
        ;;
      --branch)
        remove_branch="true"
        shift
        ;;
      --force)
        force_remove="true"
        shift
        ;;
      *)
        fail "unknown option: $1"
        ;;
    esac
  done

  local dir status source_workdir worktree_path worktree_branch
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"
  status="$(task_status_value "$name")"
  [[ "$status" != "running" ]] || fail "cannot cleanup running task: $name"

  source_workdir="$(read_file_or_empty "$dir/source-workdir")"
  worktree_path="$(read_file_or_empty "$dir/worktree-path")"
  worktree_branch="$(read_file_or_empty "$dir/worktree-branch")"

  if [[ "$remove_worktree" == "true" ]]; then
    require_command git
    [[ -n "$worktree_path" ]] || fail "task has no recorded worktree: $name"
    if [[ -e "$worktree_path" ]]; then
      local repo_for_worktree="$source_workdir"
      if [[ -z "$repo_for_worktree" || ! -d "$repo_for_worktree/.git" ]]; then
        repo_for_worktree="$worktree_path"
      fi
      local remove_args=()
      if [[ "$force_remove" == "true" ]]; then
        remove_args+=(--force)
      fi
      git -C "$repo_for_worktree" worktree remove "${remove_args[@]}" "$worktree_path" || fail "failed to remove worktree: $worktree_path"
      printf 'removed worktree %s\n' "$worktree_path"
    else
      printf 'worktree already missing %s\n' "$worktree_path"
    fi
  fi

  if [[ "$remove_branch" == "true" ]]; then
    require_command git
    [[ -n "$worktree_branch" ]] || fail "task has no recorded worktree branch: $name"
    [[ -n "$source_workdir" ]] || fail "task has no recorded source workdir: $name"
    git -C "$source_workdir" branch -D "$worktree_branch" || fail "failed to delete branch: $worktree_branch"
    printf 'deleted branch %s\n' "$worktree_branch"
  fi

  rm -rf "$dir"
  printf 'removed task %s\n' "$name"
}

cmd_stop() {
  [[ $# -eq 1 ]] || fail "stop requires one task name"
  local name="$1"
  validate_task_name "$name"

  local dir session
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"
  [[ -f "$dir/session" ]] || fail "task has no tmux session: $name"
  session="$(cat "$dir/session")"

  if tmux has-session -t "$session" >/dev/null 2>&1; then
    tmux kill-session -t "$session"
    printf 'stopped %s\n' "$name"
  else
    printf 'not running %s\n' "$name"
  fi
}

cmd_list() {
  ensure_base_dirs
  printf 'TASK\tSTATUS\tMODE\tCREATED\tWORKDIR\n'
  local dir name status mode created workdir
  shopt -s nullglob
  for dir in "$TASKS_DIR"/*; do
    [[ -d "$dir" ]] || continue
    name="$(basename "$dir")"
    status="$(task_status_value "$name")"
    mode="$(read_file_or_empty "$dir/mode")"
    created="$(read_file_or_empty "$dir/created-at")"
    workdir="$(read_file_or_empty "$dir/workdir")"
    printf '%s\t%s\t%s\t%s\t%s\n' "$name" "$status" "$mode" "$created" "$workdir"
  done
}

main() {
  [[ $# -ge 1 ]] || {
    usage
    exit 1
  }

  local command="$1"
  shift

  case "$command" in
    init) cmd_init "$@" ;;
    run) cmd_run "$@" ;;
    start) cmd_start "$@" ;;
    status) cmd_status "$@" ;;
    logs) cmd_logs "$@" ;;
    result) cmd_result "$@" ;;
    inspect) cmd_inspect "$@" ;;
    diff) cmd_diff "$@" ;;
    integrate) cmd_integrate "$@" ;;
    stop) cmd_stop "$@" ;;
    cleanup) cmd_cleanup "$@" ;;
    list) cmd_list "$@" ;;
    -h|--help|help) usage ;;
    *) fail "unknown command: $command" ;;
  esac
}

main "$@"
