#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="${CLAUDE_SUBAGENT_HOME:-$HOME/.claude-subagents}"
TASKS_DIR="$BASE_DIR/tasks"

usage() {
  cat <<'EOF'
Usage:
  claude-subagent init
  claude-subagent run <task-name> --prompt <file> --workdir <path> [--permission-mode <mode>]
  claude-subagent start <task-name> --prompt <file> --workdir <path> [--permission-mode <mode>]
  claude-subagent status <task-name>
  claude-subagent logs <task-name> [--tail <lines>]
  claude-subagent diff <task-name>
  claude-subagent stop <task-name>
  claude-subagent list

Environment:
  CLAUDE_SUBAGENT_HOME  Override storage directory. Defaults to ~/.claude-subagents.
EOF
}

fail() {
  printf 'claude-subagent: %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"
}

validate_task_name() {
  local name="$1"
  [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || fail "invalid task name: $name"
}

task_dir() {
  printf '%s/%s\n' "$TASKS_DIR" "$1"
}

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

shell_quote() {
  local value="$1"
  printf "'%s'" "${value//\'/\'\\\'\'}"
}

now_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

ensure_base_dirs() {
  mkdir -p "$TASKS_DIR"
}

read_file_or_empty() {
  local file="$1"
  if [[ -f "$file" ]]; then
    cat "$file"
  fi
}

write_metadata() {
  local dir="$1"
  local name="$2"
  local mode="$3"
  local prompt_file="$4"
  local workdir="$5"
  local permission_mode="$6"
  local session_name="${7:-}"
  local created_at
  created_at="$(now_utc)"

  printf '%s\n' "$mode" >"$dir/mode"
  printf '%s\n' "$created_at" >"$dir/created-at"
  printf '%s\n' "$workdir" >"$dir/workdir"
  printf '%s\n' "$permission_mode" >"$dir/permission-mode"
  if [[ -n "$session_name" ]]; then
    printf '%s\n' "$session_name" >"$dir/session"
  fi

  cat >"$dir/metadata.json" <<EOF
{
  "taskName": "$(json_escape "$name")",
  "mode": "$(json_escape "$mode")",
  "promptPath": "$(json_escape "$prompt_file")",
  "workdir": "$(json_escape "$workdir")",
  "permissionMode": "$(json_escape "$permission_mode")",
  "sessionName": "$(json_escape "$session_name")",
  "createdAt": "$(json_escape "$created_at")"
}
EOF
}

parse_prompt_and_workdir() {
  PROMPT_FILE=""
  WORKDIR=""
  PERMISSION_MODE="default"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --prompt)
        [[ $# -ge 2 ]] || fail "--prompt requires a file"
        PROMPT_FILE="$2"
        shift 2
        ;;
      --workdir)
        [[ $# -ge 2 ]] || fail "--workdir requires a path"
        WORKDIR="$2"
        shift 2
        ;;
      --permission-mode)
        [[ $# -ge 2 ]] || fail "--permission-mode requires a mode"
        case "$2" in
          acceptEdits|auto|bypassPermissions|default|dontAsk|plan)
            PERMISSION_MODE="$2"
            ;;
          *)
            fail "invalid permission mode: $2"
            ;;
        esac
        shift 2
        ;;
      *)
        fail "unknown option: $1"
        ;;
    esac
  done

  [[ -n "$PROMPT_FILE" ]] || fail "--prompt is required"
  [[ -f "$PROMPT_FILE" ]] || fail "prompt file not found: $PROMPT_FILE"
  [[ -n "$WORKDIR" ]] || fail "--workdir is required"
  [[ -d "$WORKDIR" ]] || fail "workdir not found: $WORKDIR"

  PROMPT_FILE="$(cd "$(dirname "$PROMPT_FILE")" && pwd)/$(basename "$PROMPT_FILE")"
  WORKDIR="$(cd "$WORKDIR" && pwd)"
}

task_status_value() {
  local name="$1"
  local dir
  dir="$(task_dir "$name")"

  if [[ ! -d "$dir" ]]; then
    printf 'unknown\n'
    return
  fi

  if [[ -f "$dir/session" ]]; then
    local session
    session="$(cat "$dir/session")"
    if tmux has-session -t "$session" >/dev/null 2>&1; then
      printf 'running\n'
      return
    fi
  fi

  if [[ -f "$dir/exit-code" ]]; then
    local code
    code="$(cat "$dir/exit-code")"
    if [[ "$code" == "0" ]]; then
      printf 'succeeded\n'
    else
      printf 'failed\n'
    fi
    return
  fi

  printf 'created\n'
}

cmd_init() {
  require_command claude
  require_command git
  require_command tmux
  ensure_base_dirs
  printf 'initialized %s\n' "$BASE_DIR"
}

cmd_run() {
  [[ $# -ge 1 ]] || fail "run requires a task name"
  local name="$1"
  shift
  validate_task_name "$name"
  parse_prompt_and_workdir "$@"
  require_command claude
  ensure_base_dirs

  local dir prompt exit_code
  dir="$(task_dir "$name")"
  rm -rf "$dir"
  mkdir -p "$dir"
  cp "$PROMPT_FILE" "$dir/prompt.md"
  write_metadata "$dir" "$name" "run" "$PROMPT_FILE" "$WORKDIR" "$PERMISSION_MODE"
  prompt="$(cat "$PROMPT_FILE")"

  set +e
  (
    cd "$WORKDIR" || exit 1
    claude "$prompt" --print --verbose --output-format stream-json --permission-mode "$PERMISSION_MODE" --add-dir "$dir" >"$dir/stdout.log" 2>"$dir/stderr.log"
  )
  exit_code=$?
  set -e

  printf '%s\n' "$exit_code" >"$dir/exit-code"
  cat "$dir/stdout.log"
  if [[ "$exit_code" -ne 0 ]]; then
    cat "$dir/stderr.log" >&2
  fi
  return "$exit_code"
}

cmd_start() {
  [[ $# -ge 1 ]] || fail "start requires a task name"
  local name="$1"
  shift
  validate_task_name "$name"
  parse_prompt_and_workdir "$@"
  require_command claude
  require_command tmux
  ensure_base_dirs

  local dir session
  dir="$(task_dir "$name")"
  session="claude-subagent-${name//./-}"

  if tmux has-session -t "$session" >/dev/null 2>&1; then
    fail "tmux session already exists: $session"
  fi

  rm -rf "$dir"
  mkdir -p "$dir"
  cp "$PROMPT_FILE" "$dir/prompt.md"
  write_metadata "$dir" "$name" "start" "$PROMPT_FILE" "$WORKDIR" "$PERMISSION_MODE" "$session"

  cat >"$dir/runner.sh" <<EOF
#!/usr/bin/env bash
set +e
cd $(shell_quote "$WORKDIR") || exit 1
prompt="\$(cat $(shell_quote "$dir/prompt.md"))"
claude "\$prompt" --print --verbose --output-format stream-json --permission-mode $(shell_quote "$PERMISSION_MODE") --add-dir $(shell_quote "$dir") >$(shell_quote "$dir/stdout.log") 2>$(shell_quote "$dir/stderr.log")
code=\$?
printf '%s\n' "\$code" >$(shell_quote "$dir/exit-code")
exit "\$code"
EOF
  chmod +x "$dir/runner.sh"

  tmux new-session -d -s "$session" "$(shell_quote "$dir/runner.sh")"
  printf 'started %s\n' "$name"
  printf 'session %s\n' "$session"
}

cmd_status() {
  [[ $# -eq 1 ]] || fail "status requires one task name"
  validate_task_name "$1"
  printf '%s\n' "$(task_status_value "$1")"
}

cmd_logs() {
  [[ $# -ge 1 ]] || fail "logs requires a task name"
  local name="$1"
  shift
  validate_task_name "$name"

  local lines=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tail)
        [[ $# -ge 2 ]] || fail "--tail requires a line count"
        lines="$2"
        shift 2
        ;;
      *)
        fail "unknown option: $1"
        ;;
    esac
  done

  local dir
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"

  if [[ -n "$lines" ]]; then
    tail -n "$lines" "$dir/stdout.log" 2>/dev/null || true
    tail -n "$lines" "$dir/stderr.log" 2>/dev/null || true
  else
    read_file_or_empty "$dir/stdout.log"
    read_file_or_empty "$dir/stderr.log"
  fi
}

cmd_diff() {
  [[ $# -eq 1 ]] || fail "diff requires one task name"
  local name="$1"
  validate_task_name "$name"

  local dir workdir
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"
  [[ -f "$dir/workdir" ]] || fail "task has no recorded workdir: $name"
  workdir="$(cat "$dir/workdir")"
  git -C "$workdir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || fail "workdir is not a git repository: $workdir"
  git -C "$workdir" diff --stat
  git -C "$workdir" diff
}

cmd_stop() {
  [[ $# -eq 1 ]] || fail "stop requires one task name"
  local name="$1"
  validate_task_name "$name"

  local dir session
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"
  [[ -f "$dir/session" ]] || fail "task has no tmux session: $name"
  session="$(cat "$dir/session")"

  if tmux has-session -t "$session" >/dev/null 2>&1; then
    tmux kill-session -t "$session"
    printf 'stopped %s\n' "$name"
  else
    printf 'not running %s\n' "$name"
  fi
}

cmd_list() {
  ensure_base_dirs
  printf 'TASK\tSTATUS\tMODE\tCREATED\tWORKDIR\n'
  local dir name status mode created workdir
  shopt -s nullglob
  for dir in "$TASKS_DIR"/*; do
    [[ -d "$dir" ]] || continue
    name="$(basename "$dir")"
    status="$(task_status_value "$name")"
    mode="$(read_file_or_empty "$dir/mode")"
    created="$(read_file_or_empty "$dir/created-at")"
    workdir="$(read_file_or_empty "$dir/workdir")"
    printf '%s\t%s\t%s\t%s\t%s\n' "$name" "$status" "$mode" "$created" "$workdir"
  done
}

main() {
  [[ $# -ge 1 ]] || {
    usage
    exit 1
  }

  local command="$1"
  shift

  case "$command" in
    init) cmd_init "$@" ;;
    run) cmd_run "$@" ;;
    start) cmd_start "$@" ;;
    status) cmd_status "$@" ;;
    logs) cmd_logs "$@" ;;
    diff) cmd_diff "$@" ;;
    stop) cmd_stop "$@" ;;
    list) cmd_list "$@" ;;
    -h|--help|help) usage ;;
    *) fail "unknown command: $command" ;;
  esac
}

main "$@"
