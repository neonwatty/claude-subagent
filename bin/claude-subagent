#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="${CLAUDE_SUBAGENT_HOME:-$HOME/.claude-subagents}"
TASKS_DIR="$BASE_DIR/tasks"
WORKTREES_DIR="$BASE_DIR/worktrees"

usage() {
  cat <<'EOF'
Usage:
  claude-subagent init
  claude-subagent run <task-name> --prompt <file> --workdir <path> [--permission-mode <mode>] [--worktree]
  claude-subagent start <task-name> --prompt <file> --workdir <path> [--permission-mode <mode>] [--worktree]
  claude-subagent status <task-name>
  claude-subagent logs <task-name> [--tail <lines>]
  claude-subagent result <task-name>
  claude-subagent diff <task-name>
  claude-subagent stop <task-name>
  claude-subagent list

Environment:
  CLAUDE_SUBAGENT_HOME  Override storage directory. Defaults to ~/.claude-subagents.
EOF
}

fail() {
  printf 'claude-subagent: %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"
}

resolve_command() {
  command -v "$1" 2>/dev/null || fail "missing required command: $1"
}

validate_task_name() {
  local name="$1"
  [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || fail "invalid task name: $name"
}

task_dir() {
  printf '%s/%s\n' "$TASKS_DIR" "$1"
}

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\t'/\\t}"
  printf '%s' "$value"
}

shell_quote() {
  local value="$1"
  printf "'%s'" "${value//\'/\'\\\'\'}"
}

now_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

ensure_base_dirs() {
  mkdir -p "$TASKS_DIR"
  mkdir -p "$WORKTREES_DIR"
}

read_file_or_empty() {
  local file="$1"
  if [[ -f "$file" ]]; then
    cat "$file"
  fi
}

extract_result() {
  local dir="$1"
  local stdout_log="$dir/stdout.log"
  local result_file="$dir/result.txt"

  [[ -f "$stdout_log" ]] || return 0

  if command -v ruby >/dev/null 2>&1; then
    ruby -rjson -e '
      texts = []
      File.foreach(ARGV[0]) do |line|
        begin
          event = JSON.parse(line)
        rescue JSON::ParserError
          next
        end

        if event["type"] == "result" && event["result"]
          texts << event["result"].to_s
        elsif event["type"] == "assistant" && event["message"].is_a?(Hash)
          Array(event["message"]["content"]).each do |part|
            if part.is_a?(Hash) && part["type"] == "text" && part["text"]
              texts << part["text"].to_s
            end
          end
        elsif event["type"] == "message" && event["content"]
          texts << event["content"].to_s
        end
      end
      puts texts.reject(&:empty?).last.to_s
    ' "$stdout_log" >"$result_file.tmp" 2>/dev/null || true

    if [[ -s "$result_file.tmp" ]]; then
      mv "$result_file.tmp" "$result_file"
      return 0
    fi
    rm -f "$result_file.tmp"
  fi

  cp "$stdout_log" "$result_file"
}

write_metadata() {
  local dir="$1"
  local name="$2"
  local mode="$3"
  local prompt_file="$4"
  local workdir="$5"
  local permission_mode="$6"
  local source_workdir="$7"
  local worktree_enabled="$8"
  local worktree_branch="$9"
  local worktree_path="${10}"
  local source_branch="${11}"
  local source_dirty="${12}"
  local session_name="${13:-}"
  local created_at
  created_at="$(now_utc)"

  printf '%s\n' "$mode" >"$dir/mode"
  printf '%s\n' "$created_at" >"$dir/created-at"
  printf '%s\n' "$workdir" >"$dir/workdir"
  printf '%s\n' "$permission_mode" >"$dir/permission-mode"
  printf '%s\n' "$source_workdir" >"$dir/source-workdir"
  printf '%s\n' "$worktree_enabled" >"$dir/worktree-enabled"
  if [[ -n "$worktree_branch" ]]; then
    printf '%s\n' "$worktree_branch" >"$dir/worktree-branch"
  fi
  if [[ -n "$worktree_path" ]]; then
    printf '%s\n' "$worktree_path" >"$dir/worktree-path"
  fi
  if [[ -n "$source_branch" ]]; then
    printf '%s\n' "$source_branch" >"$dir/source-branch"
  fi
  printf '%s\n' "$source_dirty" >"$dir/source-dirty"
  if [[ -n "$session_name" ]]; then
    printf '%s\n' "$session_name" >"$dir/session"
  fi

  cat >"$dir/metadata.json" <<EOF
{
  "taskName": "$(json_escape "$name")",
  "mode": "$(json_escape "$mode")",
  "promptPath": "$(json_escape "$prompt_file")",
  "workdir": "$(json_escape "$workdir")",
  "permissionMode": "$(json_escape "$permission_mode")",
  "sourceWorkdir": "$(json_escape "$source_workdir")",
  "worktreeEnabled": "$(json_escape "$worktree_enabled")",
  "worktreeBranch": "$(json_escape "$worktree_branch")",
  "worktreePath": "$(json_escape "$worktree_path")",
  "sourceBranch": "$(json_escape "$source_branch")",
  "sourceDirty": "$(json_escape "$source_dirty")",
  "sessionName": "$(json_escape "$session_name")",
  "createdAt": "$(json_escape "$created_at")"
}
EOF
}

parse_prompt_and_workdir() {
  PROMPT_FILE=""
  WORKDIR=""
  PERMISSION_MODE="default"
  USE_WORKTREE="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --prompt)
        [[ $# -ge 2 ]] || fail "--prompt requires a file"
        PROMPT_FILE="$2"
        shift 2
        ;;
      --workdir)
        [[ $# -ge 2 ]] || fail "--workdir requires a path"
        WORKDIR="$2"
        shift 2
        ;;
      --permission-mode)
        [[ $# -ge 2 ]] || fail "--permission-mode requires a mode"
        case "$2" in
          acceptEdits|auto|bypassPermissions|default|dontAsk|plan)
            PERMISSION_MODE="$2"
            ;;
          *)
            fail "invalid permission mode: $2"
            ;;
        esac
        shift 2
        ;;
      --worktree)
        USE_WORKTREE="true"
        shift
        ;;
      *)
        fail "unknown option: $1"
        ;;
    esac
  done

  [[ -n "$PROMPT_FILE" ]] || fail "--prompt is required"
  [[ -f "$PROMPT_FILE" ]] || fail "prompt file not found: $PROMPT_FILE"
  [[ -n "$WORKDIR" ]] || fail "--workdir is required"
  [[ -d "$WORKDIR" ]] || fail "workdir not found: $WORKDIR"

  PROMPT_FILE="$(cd "$(dirname "$PROMPT_FILE")" && pwd)/$(basename "$PROMPT_FILE")"
  WORKDIR="$(cd "$WORKDIR" && pwd)"
}

prepare_execution_workdir() {
  local name="$1"
  local dir="$2"

  SOURCE_WORKDIR="$WORKDIR"
  EXEC_WORKDIR="$WORKDIR"
  WORKTREE_BRANCH=""
  WORKTREE_PATH=""
  SOURCE_BRANCH=""
  SOURCE_DIRTY="unknown"

  if git -C "$SOURCE_WORKDIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    SOURCE_BRANCH="$(git -C "$SOURCE_WORKDIR" branch --show-current 2>/dev/null || true)"
    if [[ -z "$SOURCE_BRANCH" ]]; then
      SOURCE_BRANCH="$(git -C "$SOURCE_WORKDIR" rev-parse --short HEAD 2>/dev/null || true)"
    fi
    if [[ -n "$(git -C "$SOURCE_WORKDIR" status --porcelain)" ]]; then
      SOURCE_DIRTY="true"
    else
      SOURCE_DIRTY="false"
    fi
  fi

  if [[ "$USE_WORKTREE" != "true" ]]; then
    return
  fi

  require_command git
  git -C "$SOURCE_WORKDIR" rev-parse --is-inside-work-tree >/dev/null 2>&1 || fail "--worktree requires --workdir to be inside a git repository"

  local repo_root prefix worktree_exec_subdir
  repo_root="$(git -C "$SOURCE_WORKDIR" rev-parse --show-toplevel)"
  prefix="$(git -C "$SOURCE_WORKDIR" rev-parse --show-prefix)"
  WORKTREE_BRANCH="claude-subagent/$name"
  WORKTREE_PATH="$WORKTREES_DIR/$name"

  [[ ! -e "$WORKTREE_PATH" ]] || fail "worktree path already exists: $WORKTREE_PATH"
  if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$WORKTREE_BRANCH"; then
    fail "worktree branch already exists: $WORKTREE_BRANCH"
  fi

  git -C "$repo_root" worktree add -b "$WORKTREE_BRANCH" "$WORKTREE_PATH" HEAD >"$dir/worktree-create.log" 2>&1 || {
    cat "$dir/worktree-create.log" >&2
    fail "failed to create worktree"
  }

  worktree_exec_subdir="${prefix%/}"
  if [[ -n "$worktree_exec_subdir" ]]; then
    EXEC_WORKDIR="$WORKTREE_PATH/$worktree_exec_subdir"
  else
    EXEC_WORKDIR="$WORKTREE_PATH"
  fi
}

task_status_value() {
  local name="$1"
  local dir
  dir="$(task_dir "$name")"

  if [[ ! -d "$dir" ]]; then
    printf 'unknown\n'
    return
  fi

  if [[ -f "$dir/session" ]]; then
    local session
    session="$(cat "$dir/session")"
    if tmux has-session -t "$session" >/dev/null 2>&1; then
      printf 'running\n'
      return
    fi
  fi

  if [[ -f "$dir/exit-code" ]]; then
    local code
    code="$(cat "$dir/exit-code")"
    if [[ "$code" == "0" ]]; then
      printf 'succeeded\n'
    else
      printf 'failed\n'
    fi
    return
  fi

  printf 'created\n'
}

cmd_init() {
  require_command claude
  require_command git
  require_command tmux
  ensure_base_dirs
  printf 'initialized %s\n' "$BASE_DIR"
}

cmd_run() {
  [[ $# -ge 1 ]] || fail "run requires a task name"
  local name="$1"
  shift
  validate_task_name "$name"
  parse_prompt_and_workdir "$@"
  require_command claude
  local claude_bin
  claude_bin="$(resolve_command claude)"
  ensure_base_dirs

  local dir prompt exit_code
  dir="$(task_dir "$name")"
  rm -rf "$dir"
  mkdir -p "$dir"
  cp "$PROMPT_FILE" "$dir/prompt.md"
  prepare_execution_workdir "$name" "$dir"
  write_metadata "$dir" "$name" "run" "$PROMPT_FILE" "$EXEC_WORKDIR" "$PERMISSION_MODE" "$SOURCE_WORKDIR" "$USE_WORKTREE" "$WORKTREE_BRANCH" "$WORKTREE_PATH" "$SOURCE_BRANCH" "$SOURCE_DIRTY"
  prompt="$(cat "$PROMPT_FILE")"

  set +e
  (
    cd "$EXEC_WORKDIR" || exit 1
    "$claude_bin" "$prompt" --print --verbose --output-format stream-json --permission-mode "$PERMISSION_MODE" --add-dir "$dir" >"$dir/stdout.log" 2>"$dir/stderr.log"
  )
  exit_code=$?
  set -e

  printf '%s\n' "$exit_code" >"$dir/exit-code"
  extract_result "$dir"
  cat "$dir/stdout.log"
  if [[ "$exit_code" -ne 0 ]]; then
    cat "$dir/stderr.log" >&2
  fi
  return "$exit_code"
}

cmd_start() {
  [[ $# -ge 1 ]] || fail "start requires a task name"
  local name="$1"
  shift
  validate_task_name "$name"
  parse_prompt_and_workdir "$@"
  require_command claude
  require_command tmux
  local claude_bin
  claude_bin="$(resolve_command claude)"
  ensure_base_dirs

  local dir session
  dir="$(task_dir "$name")"
  session="claude-subagent-${name//./-}"

  if tmux has-session -t "$session" >/dev/null 2>&1; then
    fail "tmux session already exists: $session"
  fi

  rm -rf "$dir"
  mkdir -p "$dir"
  cp "$PROMPT_FILE" "$dir/prompt.md"
  prepare_execution_workdir "$name" "$dir"
  write_metadata "$dir" "$name" "start" "$PROMPT_FILE" "$EXEC_WORKDIR" "$PERMISSION_MODE" "$SOURCE_WORKDIR" "$USE_WORKTREE" "$WORKTREE_BRANCH" "$WORKTREE_PATH" "$SOURCE_BRANCH" "$SOURCE_DIRTY" "$session"

  cat >"$dir/runner.sh" <<EOF
#!/usr/bin/env bash
set +e
cd $(shell_quote "$EXEC_WORKDIR") || exit 1
prompt="\$(cat $(shell_quote "$dir/prompt.md"))"
$(shell_quote "$claude_bin") "\$prompt" --print --verbose --output-format stream-json --permission-mode $(shell_quote "$PERMISSION_MODE") --add-dir $(shell_quote "$dir") >$(shell_quote "$dir/stdout.log") 2>$(shell_quote "$dir/stderr.log")
code=\$?
printf '%s\n' "\$code" >$(shell_quote "$dir/exit-code")
if command -v ruby >/dev/null 2>&1; then
  ruby -rjson -e '
    texts = []
    File.foreach(ARGV[0]) do |line|
      begin
        event = JSON.parse(line)
      rescue JSON::ParserError
        next
      end

      if event["type"] == "result" && event["result"]
        texts << event["result"].to_s
      elsif event["type"] == "assistant" && event["message"].is_a?(Hash)
        Array(event["message"]["content"]).each do |part|
          if part.is_a?(Hash) && part["type"] == "text" && part["text"]
            texts << part["text"].to_s
          end
        end
      elsif event["type"] == "message" && event["content"]
        texts << event["content"].to_s
      end
    end
    puts texts.reject(&:empty?).last.to_s
  ' $(shell_quote "$dir/stdout.log") >$(shell_quote "$dir/result.txt.tmp") 2>/dev/null || true
  if [[ -s $(shell_quote "$dir/result.txt.tmp") ]]; then
    mv $(shell_quote "$dir/result.txt.tmp") $(shell_quote "$dir/result.txt")
  else
    rm -f $(shell_quote "$dir/result.txt.tmp")
    cp $(shell_quote "$dir/stdout.log") $(shell_quote "$dir/result.txt")
  fi
else
  cp $(shell_quote "$dir/stdout.log") $(shell_quote "$dir/result.txt")
fi
exit "\$code"
EOF
  chmod +x "$dir/runner.sh"

  tmux new-session -d -s "$session" "$(shell_quote "$dir/runner.sh")"
  printf 'started %s\n' "$name"
  printf 'session %s\n' "$session"
}

cmd_status() {
  [[ $# -eq 1 ]] || fail "status requires one task name"
  validate_task_name "$1"
  printf '%s\n' "$(task_status_value "$1")"
}

cmd_logs() {
  [[ $# -ge 1 ]] || fail "logs requires a task name"
  local name="$1"
  shift
  validate_task_name "$name"

  local lines=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tail)
        [[ $# -ge 2 ]] || fail "--tail requires a line count"
        lines="$2"
        shift 2
        ;;
      *)
        fail "unknown option: $1"
        ;;
    esac
  done

  local dir
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"

  if [[ -n "$lines" ]]; then
    tail -n "$lines" "$dir/stdout.log" 2>/dev/null || true
    tail -n "$lines" "$dir/stderr.log" 2>/dev/null || true
  else
    read_file_or_empty "$dir/stdout.log"
    read_file_or_empty "$dir/stderr.log"
  fi
}

cmd_result() {
  [[ $# -eq 1 ]] || fail "result requires one task name"
  local name="$1"
  validate_task_name "$name"

  local dir
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"
  if [[ ! -f "$dir/result.txt" && -f "$dir/stdout.log" ]]; then
    extract_result "$dir"
  fi
  [[ -f "$dir/result.txt" ]] || fail "task has no result yet: $name"
  cat "$dir/result.txt"
}

cmd_diff() {
  [[ $# -eq 1 ]] || fail "diff requires one task name"
  local name="$1"
  validate_task_name "$name"

  local dir workdir
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"
  [[ -f "$dir/workdir" ]] || fail "task has no recorded workdir: $name"
  workdir="$(cat "$dir/workdir")"
  git -C "$workdir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || fail "workdir is not a git repository: $workdir"
  git -C "$workdir" diff --stat
  git -C "$workdir" diff
}

cmd_stop() {
  [[ $# -eq 1 ]] || fail "stop requires one task name"
  local name="$1"
  validate_task_name "$name"

  local dir session
  dir="$(task_dir "$name")"
  [[ -d "$dir" ]] || fail "unknown task: $name"
  [[ -f "$dir/session" ]] || fail "task has no tmux session: $name"
  session="$(cat "$dir/session")"

  if tmux has-session -t "$session" >/dev/null 2>&1; then
    tmux kill-session -t "$session"
    printf 'stopped %s\n' "$name"
  else
    printf 'not running %s\n' "$name"
  fi
}

cmd_list() {
  ensure_base_dirs
  printf 'TASK\tSTATUS\tMODE\tCREATED\tWORKDIR\n'
  local dir name status mode created workdir
  shopt -s nullglob
  for dir in "$TASKS_DIR"/*; do
    [[ -d "$dir" ]] || continue
    name="$(basename "$dir")"
    status="$(task_status_value "$name")"
    mode="$(read_file_or_empty "$dir/mode")"
    created="$(read_file_or_empty "$dir/created-at")"
    workdir="$(read_file_or_empty "$dir/workdir")"
    printf '%s\t%s\t%s\t%s\t%s\n' "$name" "$status" "$mode" "$created" "$workdir"
  done
}

main() {
  [[ $# -ge 1 ]] || {
    usage
    exit 1
  }

  local command="$1"
  shift

  case "$command" in
    init) cmd_init "$@" ;;
    run) cmd_run "$@" ;;
    start) cmd_start "$@" ;;
    status) cmd_status "$@" ;;
    logs) cmd_logs "$@" ;;
    result) cmd_result "$@" ;;
    diff) cmd_diff "$@" ;;
    stop) cmd_stop "$@" ;;
    list) cmd_list "$@" ;;
    -h|--help|help) usage ;;
    *) fail "unknown command: $command" ;;
  esac
}

main "$@"
